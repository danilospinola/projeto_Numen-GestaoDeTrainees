{
    "[development]": {
        "requires": {
            "db": {
                "credentials": {
                    "database": ":memory:"
                },
                "kind": "sqlite"
            }
        }
    },
    "[production]": {
        "requires": {
            "db": {
                "kind": "hana",
                "model": "db"
            },
            "uaa": {
                "kind": "xsuaa"
            }
        },
        "hana": {
            "deploy-format": "hdbtable"
        }
    }

    
}